# NPM Security Configuration
# Enforces best practices for dependency management

# Require exact versions for CI/CD
ci-audit-level=high

# Prevent auto-publishing credentials
registry=https://registry.npmjs.org/

# Audit on install (optional, can slow down installs)
audit-level=high

# Verify signatures for packages (npm v7+)
audit=true

# Enforce strict dependency resolution
strict-peer-deps=true

# Log all HTTP requests for security auditing
# (disabled by default as it's verbose)
# loglevel=verbose

# Set custom timeout for registry operations
fetch-timeout=120000

# Use lockfile-only during CI
# (uncomment if using in CI environment)
# ci=true

# Prevent running install scripts from packages
# (use with caution, some packages need scripts)
# ignore-scripts=true